      "description": "Processing SLA",
      "rule_type": "sla_check",
      "parameters": {
        "ALL": 20
      },
      "effective_date": "2024-01-01"
    },
    {
      "rule_id": "HK-wait",
      "description": "Waiting period",
      "rule_type": "waiting_period",
      "parameters": {
        "general": 60,
        "pre_existing": 180
      },
      "effective_date": "2024-01-01"
    },
    {
      "rule_id": "HK-mask",
      "description": "Mask HKID",
