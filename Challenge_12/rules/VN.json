      "rule_id": "VN-sla",
      "description": "Processing SLA",
      "rule_type": "sla_check",
      "parameters": {
        "ALL": 10
      },
      "effective_date": "2024-01-01"
    },
    {
      "rule_id": "VN-wait",
      "description": "Waiting period",
      "rule_type": "waiting_period",
      "parameters": {
        "general": 30,
        "pre_existing": 365
      },
      "effective_date": "2024-01-01"
    },
    {
      "rule_id": "VN-mask",
      "description": "Mask full name",
      "rule_type": "data_masking",
      "parameters": {
        "field": "full_name",
